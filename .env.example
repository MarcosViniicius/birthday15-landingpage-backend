# =============================================================
# .env.example — birthday15-landingpage-backend
# Copie este arquivo para .env e preencha com seus dados reais
# NUNCA commite o .env com dados reais no repositório
# =============================================================

# ------------------------------------------------------------------
# Flask — Obrigatório
# ------------------------------------------------------------------
# Chave secreta usada para assinar cookies e flash messages.
# Gere uma chave forte: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=substitua_por_uma_chave_forte_gerada_aleatoriamente


# ------------------------------------------------------------------
# Dados do Evento — Recomendado (exibidos na página /pix)
# Não são credenciais sensíveis, mas evite expor em código-fonte público
# ------------------------------------------------------------------

# Chave Pix do organizador
CHAVE_PIX=coloque_a_chave_pix_aqui

# Nome do titular da conta Pix
NOME_TITULAR=Ana Beatriz Nacimento de Lucena

# Banco da conta Pix
BANCO_TITULAR=Inter

# Número WhatsApp do organizador com DDI (sem espaços ou traços)
# Exemplo: +5584999999999
WHATSAPP_ORGANIZADOR=+55XXXXXXXXXXX


# ------------------------------------------------------------------
# Flask-Mail — Necessário apenas com backend ativo
# Para reativar: descomente os blocos Flask-Mail em index.py
# ------------------------------------------------------------------

# E-mail do remetente (conta Gmail recomendada)
MAIL_USERNAME=seu_email@gmail.com

# Senha de App do Gmail (NÃO é a senha de login normal)
# Gere em: https://myaccount.google.com/apppasswords
# Exige verificação em duas etapas ativada na conta Google
MAIL_PASSWORD=xxxx_xxxx_xxxx_xxxx


# ------------------------------------------------------------------
# PostgreSQL — Necessário apenas com backend ativo
# Para reativar: descomente os blocos de banco de dados em index.py
# ------------------------------------------------------------------

# Usuário do banco de dados PostgreSQL
user=postgres

# Senha do usuário PostgreSQL
password=sua_senha_aqui

# Host do servidor PostgreSQL
# Exemplos: localhost | db.supabase.co | seu-host.neon.tech
host=localhost

# Porta do PostgreSQL (padrão: 5432)
port=5432

# Nome do banco de dados
dbname=birthday15
